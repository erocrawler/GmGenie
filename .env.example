# Bind address and port
HOST=0.0.0.0
PORT=8100

# Path to characters config (relative to repo root or absolute)
CHARACTERS_FILE=characters.json

# Lazy-load and unload behavior
# Unload a loaded character if idle longer than this many seconds (10 min default)
IDLE_UNLOAD_SECONDS=600
# How often to check idle characters for unloading
JANITOR_INTERVAL_SECONDS=30
# Max number of simultaneously loaded characters.
# When exceeded, least-recently-used character is evicted.
MAX_LOADED_CHARACTERS=1

# Optional: path to pre-downloaded GenieData folder (~391 MB).
# If unset, Genie downloads the files automatically on first run.
# GENIE_DATA_DIR=/path/to/GenieData
